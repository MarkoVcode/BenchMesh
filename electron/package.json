{
  "name": "benchmesh-electron",
  "version": "0.0.51",
  "description": "BenchMesh Electron Wrapper - Desktop application for instrument control and automation",
  "homepage": "https://github.com/yourusername/BenchMesh",
  "author": {
    "name": "BenchMesh Team",
    "email": "team@benchmesh.local"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:mac:x64": "electron-builder --mac --x64",
    "build:mac:arm64": "electron-builder --mac --arm64"
  },
  "build": {
    "appId": "com.benchmesh.app",
    "productName": "BenchMesh",
    "files": [
      "main.js",
      "preload.js",
      "../benchmesh-serial-service/frontend/dist/**/*",
      "../benchmesh-serial-service/src/**/*",
      "../benchmesh-serial-service/requirements.txt"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "../dist"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "BenchMesh Team <team@benchmesh.local>"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.developer-tools"
    },
    "extraResources": [
      {
        "from": "../.node-red",
        "to": "node-red"
      }
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "tree-kill": "^1.2.2"
  }
}
