{
  "$schema": "benchmesh.schema.instrument.profile.v1.json",
  "vendor": "OWON",
  "family": "SPM",
  "version": "1.0.0",
  "models": {
    "DEFAULT": {
      "classes": [
        "PSU",
        "DMM"
      ],
      "connection": {
        "seol": "\r",
        "reol": "\r",
        "def_conn_ver_command": "*IDN?"
      },
      "polling": [
        {
          "method": "poll_status",
          "interval": 2,
          "multi_class": true
        }
      ],
      "instrument_class": {
        "PSU": {
          "ui_component": "GenericOWONPSU",
          "features": {
            "lock": false,
            "compulsory_lock": false,
            "channels": 1,
            "memory_banks": 4,
            "memory_storage": [
              "V",
              "A",
              "OVP",
              "OCP"
            ],
            "absolute_limits": {
              "voltage": {
                "display": "V",
                "max": 30.0
              },
              "current": {
                "display": "A",
                "max": 10.0
              },
              "power": {
                "display": "W",
                "max": 300.0
              }
            },
            "modes": {
              "CC": {
                "setpoint": {
                  "type": "number",
                  "display": "A",
                  "min": 0.01,
                  "max": 10.1,
                  "step": 0.001,
                  "ui_step": 0.001
                },
                "protection": {
                  "OCP": {
                    "type": "number",
                    "display": "A",
                    "min": 0.1,
                    "max": 10.2,
                    "step": 0.001
                  }
                }
              },
              "CV": {
                "setpoint": {
                  "type": "number",
                  "display": "V",
                  "min": 0.01,
                  "max": 31.0,
                  "step": 0.01,
                  "ui_step": 0.01
                },
                "protection": {
                  "OVP": {
                    "type": "number",
                    "display": "V",
                    "min": 0.1,
                    "max": 32,
                    "step": 0.01
                  }
                }
              }
            }
          }
        },
        "DMM": {
          "ui_component": "GenericDMM",
          "features": {
            "channels": 1,
            "modes": {
              "VOLT_DC": {"unit": "V", "symbol": "U", "note": "DC", "techname": "VOLT:DC", "ui_name": "Voltage DC", "ui_component": "GenericRange"},
              "VOLT_AC": {"unit": "V", "symbol": "U", "note": "AC", "techname": "VOLT:AC", "ui_name": "Voltage AC", "ui_component": "GenericRange"},
              "CURR_DC": {"unit": "A", "symbol": "I", "note": "DC", "techname": "CURR:DC", "ui_name": "Current DC", "ui_component": "GenericRange"},
              "CURR_AC": {"unit": "A", "symbol": "I", "note": "AC", "techname": "CURR:AC", "ui_name": "Current AC", "ui_component": "GenericRange"},
              "RES": {"unit": "Ω", "symbol": "R", "techname": "RES", "ui_name": "Resistance", "ui_component": "GenericRange"},
              "CAP": {"unit": "F", "symbol": "C", "techname": "CAP", "ui_name": "Capacitance", "ui_component": "GenericRange"},
              "DIOD": {"unit": "V", "symbol": "D", "techname": "DIOD", "ui_name": "Diode"},
              "CONT": {"unit": "Ω", "symbol": "R", "note": "buzzer", "techname": "CONT", "ui_name": "Continuity"}
            },
            "hold": true,
            "delta": true,
            "RANGe": {
              "CAP": [
                {"value": "AUTO", "display": "AUTO"},
                {"value": "2E-9", "display": "2nF"},
                {"value": "20E-9", "display": "20nF"},
                {"value": "200E-9", "display": "200nF"},
                {"value": "2E-6", "display": "2µF"},
                {"value": "20E-6", "display": "20µF"},
                {"value": "200E-6", "display": "200µF"},
                {"value": "10E-3", "display": "10mF"}
              ],
              "RES": [
                {"value": "AUTO", "display": "AUTO"},
                {"value": "MIN", "display": "MINimum"},
                {"value": "MAX", "display": "MAXimum"},
                {"value": "200", "display": "200Ω"},
                {"value": "2E3", "display": "2KΩ"},
                {"value": "20E3", "display": "20KΩ"},
                {"value": "200E3", "display": "200KΩ"},
                {"value": "2E6", "display": "2MΩ"},
                {"value": "20E6", "display": "20MΩ"},
                {"value": "100E6", "display": "100MΩ"}
              ],
              "CURR_AC": [
                {"value": "AUTO", "display": "AUTO"},
                {"value": "MIN", "display": "MINimum"},
                {"value": "MAX", "display": "MAXimum"},
                {"value": "200E-3", "display": "200mA"},
                {"value": "10", "display": "10A"}
              ],
              "CURR_DC": [
                {"value": "AUTO", "display": "AUTO"},
                {"value": "MIN", "display": "MINimum"},
                {"value": "MAX", "display": "MAXimum"},
                {"value": "200E-3", "display": "200mA"},
                {"value": "10", "display": "10A"}
              ],
              "VOLT_AC": [
                {"value": "AUTO", "display": "AUTO"},
                {"value": "MIN", "display": "MINimum"},
                {"value": "MAX", "display": "MAXimum"},
                {"value": "200E-3", "display": "200mV"},
                {"value": "2", "display": "2V"},
                {"value": "20", "display": "20V"},
                {"value": "200", "display": "200V"},
                {"value": "750", "display": "750V"}
              ],
              "VOLT_DC": [
                {"value": "AUTO", "display": "AUTO"},
                {"value": "MIN", "display": "MINimum"},
                {"value": "MAX", "display": "MAXimum"},
                {"value": "200E-3", "display": "200mV"},
                {"value": "2", "display": "2V"},
                {"value": "20", "display": "20V"},
                {"value": "200", "display": "200V"},
                {"value": "1000", "display": "1000V"}
              ]
            }
          }
        }
      }
    },
    "SPM3103": {
      "id_patterns": [
        "OWON,SPM3103"
      ]
    }
  }
}
