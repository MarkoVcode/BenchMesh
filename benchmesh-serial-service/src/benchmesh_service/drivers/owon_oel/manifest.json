{
  "$schema": "benchmesh.schema.instrument.profile.v1.json",
  "vendor": "OWON",
  "family": "OEL",
  "version": "1.0.0",
  "supported_transports": ["serial"],
  "models": {
    "DEFAULT": {
      "classes": [
        "ELL"
      ],
      "connection": {
        "seol": "\r",
        "reol": "\r",
        "def_conn_ver_command": "*IDN?"
      },
      "polling": [
        {
          "method": "poll_status",
          "interval": 1.1
        }
      ],
      "instrument_class": {
        "ELL": {
          "ui_component": "OwonOELELL",
          "features": {
            "lock": true,
            "compulsory_lock": true,
            "channels": 1,
            "parallel": false,
            "dynamic_list": true,
            "remote_sense": false,
            "slew_presets": [
              "SLOW",
              "NORM",
              "FAST"
            ],
            "absolute_limits": {
              "voltage": {
                "unit": "V",
                "max": 150.0
              },
              "current": {
                "unit": "A",
                "max": 15.0
              },
              "power": {
                "unit": "W",
                "max": 150.0
              }
            },
            "modes": {
              "CURR": {
                "ui_name": "Constant Current",
                "setpoint": {
                  "unit": "A",
                  "symbol": "I",
                  "min": 0.0,
                  "max": 15.0,
                  "step": 0.001,
                  "ui_step": 0.01
                }
              },
              "VOLT": {
                "ui_name": "Constant Voltage",
                "setpoint": {
                  "unit": "V",
                  "symbol": "U",
                  "min": 0.0,
                  "max": 150.0,
                  "step": 0.01,
                  "ui_step": 0.1
                }
              },
              "RES": {
                "ui_name": "Constant Resistance",
                "setpoint": {
                  "unit": "Ω",
                  "symbol": "R",
                  "min": 0.05,
                  "max": 1000,
                  "step": 0.01,
                  "ui_step": 0.1
                }
              },
              "POW": {
                "ui_name": "Constant Power",
                "setpoint": {
                  "unit": "W",
                  "symbol": "P",
                  "min": 0.5,
                  "max": 200,
                  "step": 0.1,
                  "ui_step": 1.0
                }
              },
              "DYN": {
                "ui_name": "Dynamic"
              }
            }
          }
        }
      }
    },
