{
  "$schema": "benchmesh.schema.instrument.profile.v1.json",
  "vendor": "TENMA",
  "family": "72",
  "version": "1.0.0",
  "models": {
    "72-2540": {
      "id_patterns": [
        "TENMA 72-2540"
      ],
      "classes": [
        "PSU"
      ],
      "connection": {
        "seol": "",
        "reol": "",
        "def_conn_ver_command": "*IDN?"
      },
      "pooling": [
        {
        "method": "read_output_voltage",
        "name": "output_voltage_1",
        "interval": 0.9
        },
        {
        "method": "read_output_current",
        "name": "output_current_1",
        "interval": 0.9
        }
      ],
      "instrument_class": {
        "PSU": {
          "features": {
            "lock": true,
            "channels": 1,
            "memory_banks": 5,
            "memory_storage": [
              "V",
              "A"
            ],
            "absolute_limits": {
              "voltage": {
                "unit": "V",
                "max": 30.0
              },
              "current": {
                "unit": "A",
                "max": 5.0
              },
              "power": {
                "unit": "W",
                "max": 150.0
              }
            }
          },
          "modes": {
            "CC": {
              "setpoint": {
                "unit": "A",
                "min": 0.01,
                "max": 5.0,
                "step": 0.001,
                "ui_step": 0.001
              },
              "protection": {
                "OCP": {
                  "type": "boolean"
                }
              }
            },
            "CV": {
              "setpoint": {
                "unit": "V",
                "min": 0.01,
                "max": 30.0,
                "step": 0.01,
                "ui_step": 0.01
              },
              "protection": {
                "OVP": {
                  "type": "boolean"
                }
              }
            }
          }
        }
      }
    }
  }
}